---
import BaseLayout from "../../layout/BaseLayout.astro";
import HomeContent from "../../components/HomeContent.astro";
import { ui } from "../../i18n/ui";

export async function getStaticPaths() {
  const pages = [
    { lang: "en" },
    { lang: "de" },
    { lang: "fr" },
    { lang: "es" },
    { lang: "ca" },
  ];
  return pages.map(({ lang }) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langKey = lang as keyof typeof ui;
---

<BaseLayout lang={langKey} includeLeaflet>
  <HomeContent lang={langKey} />
</BaseLayout>
