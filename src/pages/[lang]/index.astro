---
import "@/styles/globals.css";
import Logo from "../../components/Logo.astro";
import { NavMenu } from "../../components/ui/NavMenu";
import { CarouselWrapper } from "../../components/ui/CarouselWrapper";
import TitlePage from "../../components/TitlePage.astro";
import Service from "../../components/Service.astro";
import MapWrapper from "../../components/MapWrapper.astro";
import Gallery from "../../components/Gallery.astro";
import NavMobile from "../../components/NavMobile";
import InstagramIcon from "../../components/icons/InstagramIcon.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import Modal from "../../components/Modal";
import FirmasLogos from "../../components/FirmasLogos";
import CookiesBanner from "../../components/CookiesBanner";
import Footer from "../../components/Footer.astro";
import { useTranslations } from "../../i18n/utils";
import LanguageSelector from "../../components/LanguageSelector";
import { ui } from "../../i18n/ui";

const heroImages = [
  {
    path: "../images/Limpieza-facial-profunda.jpg",
    alt: "Limpieza facial profunda",
  },
  {
    path: "../images/beauty-face-massage-56884.jpg",
    alt: "Belleza masaje de cara",
  },
  {
    path: "../images/7eb0dcf310238450490b27502631cb48.jpg",
    alt: "Masaje de chocolate",
  },
];

const images2 = [
  {
    path: "./images/Limpieza-facial-profunda-resized.jpg",
    alt: "Limpieza facial profunda",
  },
  {
    path: "./images/beauty-face-massage-56884-resized.jpg",
    alt: "Belleza masaje de cara",
  },
  {
    path: "./images/7eb0dcf310238450490b27502631cb48-resized.jpg",
    alt: "Masaje de chocolate",
  },
  {
    path: "./images/medicina-estetica-mujer-1024x492-resized.jpg",
    alt: "Mujer haciendose tratamiento de estetica",
  },
];

const logos = [
  {
    src: "../images/ballancer-platinum-logo-2.png",
    alt: "Logo de Ballancer",
  },
  {
    src: "../images/nyxpert-logo.png",
    alt: "Logo de nyxpert",
  },
  {
    src: "../images/logo-rollaction-nuevo.png",
    alt: "Logo de System Roll Action",
  },
  {
    src: "../images/lucanni-logo.png",
    alt: "Logo de Lucanni",
  },
  {
    src: "../images/thuya-logo.jfif",
    alt: "Logo de Thuya",
  },
];

export async function getStaticPaths() {
  const pages = [
    { lang: "en" },
    { lang: "de" },
    { lang: "fr" },
    { lang: "es" },
    { lang: "ca" },
  ];
  return pages.map(({ lang }) => {
    return {
      params: { lang },
    };
  });
}

let { lang } = Astro.params;
const langCast = lang as keyof typeof ui;
const t = useTranslations(langCast);

const navRoutes = [
  { label: t("routes.home"), href: "#home" },
  { label: t("routes.services"), href: "#servicios" },
  { label: t("routes.gallery"), href: "#galeria" },
  { label: t("routes.ubication"), href: "#ubicacion" },
];
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Estetica Derma - Centro de estética facial, corporal y SPA"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script is:inline src="https://unpkg.com/leaflet/dist/leaflet.js" defer
    ></script>
    <title>Estetica Derma</title>
  </head>
  <body>
    <Modal title={t("popup.bono.regalo")} client:load>
      <p class="font-body text-base md:text-lg leading-relaxed">{t("popup.bono")}</p>
      <p class="font-body text-base md:text-lg leading-relaxed mt-4">
        <a class="text-primary font-medium hover:underline" href="https://wa.me/34691310652"
          >{t("popup.contact")}</a
        >
        {t("popup.more_info")}
      </p>
    </Modal>

    <header class="fixed top-0 left-0 right-0 z-40 transition-all duration-300 bg-warm-white/95 backdrop-blur-sm shadow-sm">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <div class="flex items-center justify-between h-20 lg:h-24">
          <a href="#home" class="transition-opacity hover:opacity-80">
            <Logo title="Derma" subtitle={t("logo.subtitle")} />
          </a>

          <div class="hidden lg:flex items-center gap-8">
            <NavMenu routes={navRoutes} client:visible />
            <div class="h-6 w-px bg-brand-border"></div>
            <InstagramIcon />
            <LanguageSelector lang={lang} client:load />
          </div>

          <div class="flex items-center gap-3 lg:hidden">
            <InstagramIcon />
            <NavMobile routes={navRoutes} client:visible />
            <LanguageSelector lang={lang} client:load />
          </div>
        </div>
      </div>
    </header>

    <main>
      <section
        id="home"
        class="relative h-[55vh] lg:h-[65vh] flex items-center justify-center overflow-hidden pt-20 lg:pt-24"
      >
        <div class="absolute inset-0 z-0">
          <CarouselWrapper images={heroImages} className="h-[55vh] lg:h-[65vh]" client:load />
          <div class="absolute inset-0 bg-gradient-to-b from-cream/60 via-cream/50 to-cream/75"></div>
        </div>

        <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-10 text-center">
          <h1 class="font-display text-4xl md:text-5xl lg:text-7xl font-bold text-brand-text mt-3 animate-fade-up" style="animation-delay: 0.25s; opacity: 0;">
            {t("home.subtitle")}
          </h1>
          <div class="w-16 h-[3px] bg-secondary mx-auto mt-6 rounded-full animate-fade-up" style="animation-delay: 0.4s; opacity: 0;"></div>
          <p class="font-body text-base md:text-lg lg:text-xl text-brand-muted max-w-2xl mx-auto mt-6 leading-relaxed animate-fade-up" style="animation-delay: 0.55s; opacity: 0;">
            {t("home.p1")}
          </p>
          <div class="mt-8 animate-fade-up" style="animation-delay: 0.7s; opacity: 0;">
            <a
              href="https://wa.me/34691310652"
              class="inline-flex items-center justify-center px-8 py-3.5 rounded-full bg-primary text-white font-body font-medium text-base transition-all duration-300 hover:bg-primary-dark hover:shadow-lg"
            >
              Reserva tu cita
            </a>
          </div>
        </div>
      </section>

      <section id="servicios" class="py-16 md:py-24 lg:py-32 bg-warm-white">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
          <TitlePage
            title={t("routes.services")}
            subtitle="Tratamientos a tu medida"
          />
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mt-12 lg:mt-16">
            <Service
              iconType="spa"
              title={t("services.spa.title")}
              summary="Rituales de relajación inspirados en técnicas ancestrales para cuerpo y mente."
              items={[
                t("services.spa.1"),
                t("services.spa.2"),
                t("services.spa.3"),
                t("services.spa.4"),
                t("services.spa.5"),
                t("services.spa.6"),
                t("services.spa.7"),
                t("services.spa.8"),
                t("services.spa.9"),
                t("services.spa.10"),
                t("services.spa.11"),
                t("services.spa.12"),
                t("services.spa.13"),
              ]}
            />

            <Service
              iconType="facial"
              title={t("services.facial.title")}
              summary="Tratamientos personalizados para luminosidad, hidratación y rejuvenecimiento facial."
              items={[
                t("services.facial.1"),
                t("services.facial.2"),
                t("services.facial.3"),
                t("services.facial.4"),
                t("services.facial.5"),
                t("services.facial.6"),
                t("services.facial.7"),
                t("services.facial.8"),
                t("services.facial.9"),
                t("services.facial.10"),
                t("services.facial.11"),
                t("services.facial.12"),
                t("services.facial.13"),
              ]}
            />

            <Service
              iconType="body"
              title={t("services.body.title")}
              summary="Masajes terapéuticos y tratamientos corporales para moldear, relajar y tonificar."
              items={[
                t("services.body.1"),
                t("services.body.2"),
                t("services.body.3"),
                t("services.body.4"),
                t("services.body.5"),
                t("services.body.6"),
                t("services.body.7"),
                t("services.body.8"),
                t("services.body.9"),
                t("services.body.10"),
                t("services.body.11"),
                t("services.body.12"),
                t("services.body.13"),
              ]}
            />
          </div>
        </div>
      </section>

      <section id="galeria" class="py-16 md:py-24 lg:py-32 bg-cream">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
          <TitlePage
            title={t("gallery.title")}
            subtitle={t("gallery.subtitle")}
          />
          <div class="mt-12 lg:mt-16">
            <Gallery images={images2} />
          </div>
        </div>
      </section>

      <FirmasLogos title={t("firmas.title")} images={logos} client:load />

      <section id="ubicacion" class="py-16 md:py-24 lg:py-32 bg-warm-white">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
          <TitlePage
            title={t("ubication.title")}
            subtitle={t("ubication.subtitle")}
          />
          <div class="mt-12 lg:mt-16 rounded-2xl overflow-hidden shadow-lg border border-brand-border">
            <a href="https://maps.app.goo.gl/tpbQ5mXdgCtMiAWz7" class="block">
              <MapWrapper />
            </a>
          </div>
        </div>
      </section>

      <section id="contacta" class="w-full bg-cream py-16 md:py-24">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">
            <div>
              <h3 class="font-body text-xs font-medium uppercase tracking-widest text-primary mb-4">
                {t("about.us.title")}
              </h3>
              <p class="font-body text-base text-brand-muted leading-relaxed">
                {t("about.us.p1")}
              </p>
              <p class="font-body text-base text-brand-muted leading-relaxed mt-2">
                {t("about.us.p2")}
              </p>
            </div>
            <div>
              <h3 class="font-body text-xs font-medium uppercase tracking-widest text-primary mb-4">
                {t("about.horary.title")}
              </h3>
              <ul class="space-y-2">
                <li class="font-body text-base text-brand-muted">{t("about.horary.p1")}</li>
                <li class="font-body text-base text-brand-muted">{t("about.horary.p2")}</li>
                <li class="font-body text-base text-brand-muted">{t("about.horary.p3")}</li>
              </ul>
            </div>
            <div>
              <h3 class="font-body text-xs font-medium uppercase tracking-widest text-primary mb-4">
                {t("about.contact.title")}
              </h3>
              <ul class="space-y-2">
                <li class="font-body text-base text-brand-muted">{t("about.contact.p1")}</li>
                <li class="font-body text-base text-brand-muted">{t("about.contact.p2")}</li>
                <li class="font-body text-base text-brand-muted">{t("about.contact.p3")}</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <CookiesBanner
        client:load
        title={t("cookies.title")}
        p1={t("cookies.p1")}
        click={t("cookies.click")}
        acceptText={t("cookies.accept")}
        usage={t("cookies.usage")}
        readMore={t("cookies.read_more")}
        declineText={t("cookies.decline")}
        demo={false}
        onAcceptCallback={() => {}}
        onDeclineCallback={() => {}}
      />
    </main>

    <Footer
      subtitle={t("logo.subtitle")}
      address={t("about.contact.p1")}
      contact={t("contact")}
      company={t("empresa")}
      services={t("servicios")}
      cookiesPolicy={t("cookies_policy")}
      privacyPolicy={t("privacy_policy")}
      legalPolicy={t("legal_policy")}
    />
    <WhatsAppButton />
  </body>
</html>
