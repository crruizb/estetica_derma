---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="flex flex-col items-center text-center">
  <span class="font-display text-lg md:text-xl text-primary">{title}</span>
  <h2 class="font-display text-3xl md:text-5xl font-semibold text-brand-text mt-2">
    {subtitle}
  </h2>
  <div class="w-16 h-[3px] bg-secondary mt-6 rounded-full"></div>
</div>
