---
const { title, subtitle } = Astro.props;
---

<div class="flex flex-col">
  <span class="font-display text-2xl lg:text-3xl font-bold text-brand-text leading-none">
    {title}
  </span>
  <span class="font-body text-xs lg:text-sm text-brand-text/80 mt-0.5 max-w-[16rem] leading-tight">
    {subtitle}
  </span>
</div>
