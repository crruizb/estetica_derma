---
const {
  subtitle,
  address,
  contact,
  company,
  services,
  cookiesPolicy,
  privacyPolicy,
  legalPolicy,
} = Astro.props;
---

<footer class="bg-warm-white border-t border-brand-border w-full">
  <div class="mx-auto max-w-7xl px-6 lg:px-10 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">
      <div>
        <h2 class="font-display text-2xl font-bold text-brand-text">Derma</h2>
        <p class="font-body text-sm text-brand-muted mt-2 max-w-xs">{subtitle}</p>
      </div>

      <div>
        <h3 class="font-body text-xs font-medium uppercase tracking-widest text-primary mb-4">
          {contact}
        </h3>
        <ul class="space-y-2">
          <li class="font-body text-sm text-brand-muted">{address}</li>
          <li>
            <a
              href="mailto:contacto@esteticaderma.com"
              class="font-body text-sm text-brand-muted hover:text-primary transition-colors"
            >
              contacto@esteticaderma.com
            </a>
          </li>
          <li class="font-body text-sm text-brand-muted">934 385 970 – 691 310 652</li>
        </ul>
      </div>

      <div>
        <h3 class="font-body text-xs font-medium uppercase tracking-widest text-primary mb-4">
          {company}
        </h3>
        <ul class="grid grid-cols-2 gap-2">
          <li>
            <a href="/#servicios" class="font-body text-sm text-brand-muted hover:text-primary transition-colors">
              {services}
            </a>
          </li>
          <li>
            <a href="/politica-cookies" class="font-body text-sm text-brand-muted hover:text-primary transition-colors">
              {cookiesPolicy}
            </a>
          </li>
          <li>
            <a href="/politica-privacidad" class="font-body text-sm text-brand-muted hover:text-primary transition-colors">
              {privacyPolicy}
            </a>
          </li>
          <li>
            <a href="/aviso-legal" class="font-body text-sm text-brand-muted hover:text-primary transition-colors">
              {legalPolicy}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-brand-border text-center">
      <p class="font-body text-xs text-brand-muted">
        Copyright © {new Date().getFullYear()} Derma. All rights reserved.
      </p>
      <p class="font-body text-xs text-brand-muted mt-1">
        Designed by: <a href="https://cristianruiz.dev" target="_blank" class="hover:text-primary transition-colors">cristianruiz.dev</a>
      </p>
    </div>
  </div>
</footer>
