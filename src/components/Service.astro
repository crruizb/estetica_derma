---
interface Props {
  iconType: "spa" | "facial" | "body";
  title: string;
  summary: string;
  items: string[];
  showMoreLabel?: string;
}

const { iconType, title, summary, items, showMoreLabel = "Ver tratamientos" } = Astro.props;

const icons = {
  spa: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  facial: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  body: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`,
};
---

<article class="bg-warm-white border border-brand-border rounded-2xl p-6 lg:p-8 flex flex-col h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
  <div class="w-14 h-14 rounded-full bg-cream flex items-center justify-center text-primary mb-5">
    <Fragment set:html={icons[iconType]} />
  </div>
  
  <h3 class="font-display text-xl lg:text-2xl font-semibold text-brand-text">
    {title}
  </h3>
  
  <p class="font-body text-sm lg:text-base text-brand-muted mt-2 leading-relaxed">
    {summary}
  </p>

    <details class="mt-5 lg:hidden group">
    <summary class="font-body text-sm font-medium text-primary cursor-pointer list-none flex items-center gap-2">
      {showMoreLabel}
      <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/></svg>
    </summary>
    <ul class="mt-3 space-y-2 pl-1">
      {items.map((item) => (
        <li class="font-body text-sm text-brand-muted flex items-start gap-2">
          <span class="w-1 h-1 rounded-full bg-secondary mt-2 shrink-0"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </details>

  <ul class="mt-5 hidden lg:flex flex-col gap-2">
    {items.map((item) => (
      <li class="font-body text-sm text-brand-muted flex items-start gap-2">
        <span class="w-1 h-1 rounded-full bg-secondary mt-2 shrink-0"></span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</article>
